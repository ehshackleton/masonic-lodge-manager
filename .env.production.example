# Copiar a .env.production en la VM (no versionar; ver .gitignore). Sustituir secretos.
#
# DNS (manual): registro A/AAAA para logia.amenti.cl → IP pública de la VM.
# Docker: la red externa "proxy" debe existir (docker network create proxy) y Traefik activo.
#
# --- RAILS_MASTER_KEY (obligatorio, formato estricto) ---
# Debe ser EXACTAMENTE el contenido de config/master.key del MISMO commit que
# config/credentials.yml.enc (32 caracteres hex 0-9a-f, una sola línea).
# Sin comillas, sin espacios ni salto de línea al final (evita "key must be 16 bytes").
# NO uses el secret_key_base de las credentials ni un placeholder literal.
#
# --- SECRET_KEY_BASE ---
# Cadena larga: generar con `bin/rails secret`. Es distinta de RAILS_MASTER_KEY.
#
# --- PostgreSQL: error "role masonic does not exist" ---
# El volumen postgres_data solo se inicializa en el PRIMER arranque. Si ya existía
# con otro POSTGRES_USER, el rol "masonic" no existirá.
# Opción A (pierde datos de esa DB): docker compose -f docker-compose.production.yml down -v
# Opción B: en DATABASE_URL* usar el usuario que sí exista, o crear el rol en Postgres.
#
# Logs: docker logs CONTENEDOR 2>&1 | tail -n 100   (no: docker logs ID | tail 100)
#
# URLs de Postgres: mismo usuario/clave/host (servicio "db") y distinta base por rol.

POSTGRES_USER=masonic
POSTGRES_PASSWORD=cambiar_password_seguro

DATABASE_URL=postgres://masonic:cambiar_password_seguro@db/app_production
CACHE_DATABASE_URL=postgres://masonic:cambiar_password_seguro@db/app_production_cache
QUEUE_DATABASE_URL=postgres://masonic:cambiar_password_seguro@db/app_production_queue
CABLE_DATABASE_URL=postgres://masonic:cambiar_password_seguro@db/app_production_cable

RAILS_MASTER_KEY=reemplazar_con_los_32_hex_de_config_master_key
SECRET_KEY_BASE=reemplazar_salida_de_bin_rails_secret

# Host público (sin esquema); usado por Rails (hosts, mailers).
APP_HOST=logia.amenti.cl

# Opcional: regla Traefik completa (por defecto Host(`logia.amenti.cl`)).
# TRAEFIK_HOST_RULE=Host(`logia.amenti.cl`) || Host(`www.logia.amenti.cl`)

RAILS_LOG_LEVEL=info
ACTIVE_STORAGE_SERVICE=local
ADMIN_TEMP_PASSWORD=
