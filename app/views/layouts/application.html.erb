<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Sistema de Gestion Logial" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Sistema de Gestion Logial">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              ink: "#f4f4f5",
              brand: "#60a5fa",
              accent: "#f59e0b"
            }
          }
        }
      }
    </script>
    <style>
      input,
      select,
      textarea {
        background-color: #18181b !important;
        color: #f4f4f5 !important;
        border-color: #3f3f46 !important;
      }
      input::placeholder,
      textarea::placeholder {
        color: #a1a1aa !important;
      }
      button,
      a {
        text-underline-offset: 2px;
      }
      .border-zinc-700.text-zinc-200 {
        color: #e4e4e7 !important;
        border-color: #52525b !important;
      }
      .border-zinc-700.text-zinc-200:hover {
        color: #f59e0b !important;
        border-color: #f59e0b !important;
      }
      .text-amber-300 {
        color: #fbbf24 !important;
      }
      .text-amber-300:hover {
        color: #fcd34d !important;
      }
      .theme-light body { background-color: #f8fafc !important; color: #0f172a !important; }
      .theme-light .bg-zinc-950 { background-color: #f8fafc !important; }
      .theme-light .bg-zinc-950\/95 { background-color: rgba(248, 250, 252, 0.95) !important; }
      .theme-light .bg-zinc-950\/80 { background-color: rgba(248, 250, 252, 0.8) !important; }
      .theme-light .bg-zinc-950\/70 { background-color: rgba(248, 250, 252, 0.7) !important; }
      .theme-light .bg-zinc-950\/40 { background-color: rgba(248, 250, 252, 0.4) !important; }
      .theme-light .bg-zinc-900 { background-color: #ffffff !important; }
      .theme-light .bg-zinc-900\/80 { background-color: rgba(255, 255, 255, 0.86) !important; }
      .theme-light .bg-zinc-900\/70 { background-color: rgba(255, 255, 255, 0.78) !important; }
      .theme-light .border-zinc-800 { border-color: #e2e8f0 !important; }
      .theme-light .border-zinc-700 { border-color: #cbd5e1 !important; }
      .theme-light .text-zinc-100 { color: #0f172a !important; }
      .theme-light .text-zinc-200 { color: #1e293b !important; }
      .theme-light .text-zinc-300 { color: #334155 !important; }
      .theme-light .text-zinc-400 { color: #475569 !important; }
      .theme-light .text-zinc-500 { color: #64748b !important; }
      .theme-light .text-xs.text-zinc-500 { color: #475569 !important; }
      .theme-light .text-xs.text-zinc-400 { color: #334155 !important; }
      .theme-light .tracking-wide.text-zinc-500 { color: #475569 !important; }
      .theme-light .bg-black { background-color: #0f172a !important; }
      .theme-light .from-zinc-900,
      .theme-light .via-zinc-950,
      .theme-light .to-zinc-900 { background-image: linear-gradient(135deg, #ffffff, #f8fafc, #ffffff) !important; }
      .theme-light .hover\:bg-zinc-700:hover { background-color: #334155 !important; }
      .theme-light .hover\:bg-zinc-800\/60:hover { background-color: #e2e8f0 !important; }
      .theme-light .bg-amber-950\/30 { background-color: rgba(253, 246, 227, 0.8) !important; }
      .theme-light .bg-amber-950\/50 { background-color: rgba(253, 246, 227, 0.95) !important; }
      .theme-light .bg-emerald-950\/50 { background-color: rgba(236, 253, 245, 0.95) !important; }
      .theme-light .text-amber-300 { color: #b45309 !important; }
      .theme-light .text-amber-200 { color: #92400e !important; }
      .theme-light .text-emerald-300 { color: #047857 !important; }
      .theme-light .border-amber-800 { border-color: #d97706 !important; }
      .theme-light .border-emerald-800 { border-color: #059669 !important; }
      .theme-light input,
      .theme-light select,
      .theme-light textarea {
        background-color: #ffffff !important;
        color: #0f172a !important;
        border-color: #cbd5e1 !important;
      }
      .theme-light input::placeholder,
      .theme-light textarea::placeholder { color: #64748b !important; }
      .theme-light .text-amber-300 { color: #92400e !important; }
      .theme-light .text-emerald-300 { color: #065f46 !important; }
      .theme-light .bg-amber-950\/40 { background-color: rgba(254, 243, 199, 0.95) !important; }
      .theme-light .bg-emerald-950\/40 { background-color: rgba(209, 250, 229, 0.95) !important; }
      .theme-light .border-amber-800 { border-color: #b45309 !important; }
      .theme-light .border-emerald-800 { border-color: #047857 !important; }
      .theme-light .text-zinc-500.uppercase { color: #475569 !important; }
      .theme-light .border-zinc-700.text-zinc-200 {
        color: #1e293b !important;
        border-color: #94a3b8 !important;
      }
      .theme-light .border-zinc-700.text-zinc-200:hover {
        color: #92400e !important;
        border-color: #b45309 !important;
      }
      .theme-light a.text-amber-300 {
        color: #92400e !important;
      }
      .theme-light a.text-amber-300:hover {
        color: #78350f !important;
      }
    </style>
    <script>
      (function() {
        function applyTheme(theme) {
          document.documentElement.classList.toggle("theme-light", theme === "light");
          localStorage.setItem("theme", theme);
          var label = document.getElementById("theme-toggle-label");
          if (label) label.textContent = theme === "light" ? "Light" : "Dark";
        }

        var saved = localStorage.getItem("theme");
        applyTheme(saved || "dark");

        document.addEventListener("DOMContentLoaded", function() {
          var button = document.getElementById("theme-toggle");
          if (!button) return;
          button.addEventListener("click", function() {
            var isLight = document.documentElement.classList.contains("theme-light");
            applyTheme(isLight ? "dark" : "light");
          });
        });
      })();
    </script>
  </head>

  <body class="min-h-screen bg-zinc-950 text-zinc-100 antialiased">
    <div class="pointer-events-none fixed inset-0 -z-10 overflow-hidden">
      <div class="absolute -left-24 top-0 h-80 w-80 rounded-full bg-brand/20 blur-3xl"></div>
      <div class="absolute -right-24 top-48 h-96 w-96 rounded-full bg-accent/20 blur-3xl"></div>
      <div class="absolute bottom-0 left-1/3 h-72 w-72 rounded-full bg-emerald-500/10 blur-3xl"></div>
    </div>
    <header class="border-b border-zinc-800 bg-zinc-950/80 backdrop-blur-xl">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <a href="/" class="text-lg font-semibold tracking-tight text-ink">Sistema de Gestion Logial</a>
        <nav class="hidden items-center gap-6 text-sm font-medium md:flex">
          <a href="/" class="text-zinc-400 transition hover:text-amber-300">Inicio</a>
          <a href="/sobre-nosotros" class="text-zinc-400 transition hover:text-amber-300">Sobre nosotros</a>
          <a href="/contacto" class="text-zinc-400 transition hover:text-amber-300">Contacto</a>
          <a href="/sobre-el-sistema" class="text-zinc-400 transition hover:text-amber-300">Sobre el sistema</a>
        </nav>
        <div class="flex items-center gap-3">
          <button id="theme-toggle" type="button" class="rounded-lg border border-zinc-700 px-3 py-2 text-xs font-semibold text-zinc-200 transition hover:border-amber-300 hover:text-amber-300">
            Tema: <span id="theme-toggle-label">Dark</span>
          </button>
          <% if user_signed_in? %>
            <a href="/backoffice/perfil" class="rounded-lg border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-amber-300 hover:text-amber-300">Mi perfil</a>
            <a href="/backoffice" class="rounded-lg bg-black px-4 py-2 text-sm font-semibold text-white transition hover:bg-zinc-700">Backoffice</a>
            <%= button_to "Cerrar sesion", "/cerrar-sesion", method: :delete, class: "rounded-lg border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-amber-300 hover:text-amber-300" %>
          <% else %>
            <a href="/iniciar-sesion" class="rounded-lg border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200 transition hover:border-amber-300 hover:text-amber-300">Iniciar sesion</a>
            <a href="/backoffice" class="rounded-lg bg-black px-4 py-2 text-sm font-semibold text-white transition hover:bg-zinc-700">Backoffice</a>
          <% end %>
        </div>
      </div>
    </header>

    <main>
      <% if flash[:notice] %>
        <div class="mx-auto mt-4 max-w-7xl rounded-lg border border-emerald-800 bg-emerald-950/50 px-4 py-3 text-sm text-emerald-300">
          <%= flash[:notice] %>
        </div>
      <% end %>
      <% if flash[:alert] %>
        <div class="mx-auto mt-4 max-w-7xl rounded-lg border border-amber-800 bg-amber-950/50 px-4 py-3 text-sm text-amber-300">
          <%= flash[:alert] %>
        </div>
      <% end %>
      <%= yield %>
    </main>

    <footer class="mt-16 border-t border-zinc-800/80 bg-zinc-950/70 backdrop-blur">
      <div class="mx-auto flex max-w-7xl flex-col gap-4 px-6 py-8 text-sm text-zinc-400 md:flex-row md:items-center md:justify-between">
        <p>Gestion institucional, trazabilidad y resguardo documental para logias.</p>
        <p>V1 - Portal publico y backoffice inicial</p>
      </div>
    </footer>
  </body>
</html>
