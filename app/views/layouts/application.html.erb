<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Sistema de Gestion Logial" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Sistema de Gestion Logial">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
      tailwind.config = {
        theme: {
          extend: {
            colors: {
              ink: "#0f172a",
              brand: "#1d4ed8",
              accent: "#b45309"
            }
          }
        }
      }
    </script>
  </head>

  <body class="min-h-screen bg-slate-50 text-slate-800 antialiased">
    <header class="border-b border-slate-200 bg-white/95 backdrop-blur">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-6 py-4">
        <a href="/" class="text-lg font-semibold tracking-tight text-ink">Sistema de Gestion Logial</a>
        <nav class="hidden items-center gap-6 text-sm font-medium md:flex">
          <a href="/" class="text-slate-600 transition hover:text-brand">Inicio</a>
          <a href="/sobre-nosotros" class="text-slate-600 transition hover:text-brand">Sobre nosotros</a>
          <a href="/contacto" class="text-slate-600 transition hover:text-brand">Contacto</a>
          <a href="/sobre-el-sistema" class="text-slate-600 transition hover:text-brand">Sobre el sistema</a>
        </nav>
        <div class="flex items-center gap-3">
          <a href="/iniciar-sesion" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700 transition hover:border-brand hover:text-brand">Iniciar sesion</a>
          <a href="/backoffice" class="rounded-lg bg-ink px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-700">Backoffice</a>
        </div>
      </div>
    </header>

    <main>
      <%= yield %>
    </main>

    <footer class="mt-16 border-t border-slate-200 bg-white">
      <div class="mx-auto flex max-w-7xl flex-col gap-4 px-6 py-8 text-sm text-slate-600 md:flex-row md:items-center md:justify-between">
        <p>Gestion institucional, trazabilidad y resguardo documental para logias.</p>
        <p>V1 - Portal publico y backoffice inicial</p>
      </div>
    </footer>
  </body>
</html>
