<% content_for :title, "Contacto | Sistema de Gestion Logial" %>

<section class="mx-auto max-w-5xl px-6 py-14">
  <div class="grid gap-8 lg:grid-cols-2">
    <div>
      <h1 class="text-4xl font-bold tracking-tight text-ink">Contacto</h1>
      <p class="mt-4 text-slate-600">
        Si requiere informacion institucional, use este canal.
        El acceso al backoffice es exclusivo para usuarios autorizados.
      </p>
      <div class="mt-6 space-y-3 rounded-xl border border-slate-200 bg-white p-5 text-sm text-slate-600">
        <p><span class="font-semibold text-ink">Correo:</span> contacto@logia.local</p>
        <p><span class="font-semibold text-ink">Telefono:</span> +56 9 0000 0000</p>
        <p><span class="font-semibold text-ink">Direccion:</span> Orient de referencia, Chile</p>
      </div>
    </div>

    <form class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-ink">Formulario de contacto</h2>
      <div class="mt-4 space-y-4">
        <label class="block text-sm font-medium text-slate-700">Nombre
          <input type="text" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand focus:outline-none focus:ring-2 focus:ring-blue-100" placeholder="Nombre completo">
        </label>
        <label class="block text-sm font-medium text-slate-700">Correo
          <input type="email" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand focus:outline-none focus:ring-2 focus:ring-blue-100" placeholder="correo@dominio.com">
        </label>
        <label class="block text-sm font-medium text-slate-700">Asunto
          <input type="text" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand focus:outline-none focus:ring-2 focus:ring-blue-100" placeholder="Motivo del mensaje">
        </label>
        <label class="block text-sm font-medium text-slate-700">Mensaje
          <textarea rows="4" class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 text-sm focus:border-brand focus:outline-none focus:ring-2 focus:ring-blue-100" placeholder="Escriba su mensaje"></textarea>
        </label>
        <button type="button" class="w-full rounded-lg bg-ink px-4 py-2.5 text-sm font-semibold text-white hover:bg-slate-700">
          Enviar mensaje
        </button>
      </div>
    </form>
  </div>
</section>
