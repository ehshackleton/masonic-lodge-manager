<% content_for :title, "Contacto | Sistema de Gestion Logial" %>

<section class="mx-auto max-w-5xl px-6 py-14">
  <div class="grid gap-8 lg:grid-cols-2">
    <div>
      <h1 class="text-4xl font-bold tracking-tight text-zinc-100">Contacto</h1>
      <p class="mt-4 text-zinc-400">
        Si requiere informacion institucional, use este canal.
        El acceso al backoffice es exclusivo para usuarios autorizados.
      </p>
      <div class="mt-6 space-y-3 rounded-2xl border border-zinc-800 bg-zinc-900/80 p-5 text-sm text-zinc-400 backdrop-blur">
        <p><span class="font-semibold text-zinc-100">Correo:</span> contacto@logia.local</p>
        <p><span class="font-semibold text-zinc-100">Telefono:</span> +56 9 0000 0000</p>
        <p><span class="font-semibold text-zinc-100">Direccion:</span> Orient de referencia, Chile</p>
      </div>
    </div>

    <form class="rounded-3xl border border-zinc-800 bg-zinc-900/80 p-6 shadow-sm backdrop-blur">
      <h2 class="text-lg font-semibold text-zinc-100">Formulario de contacto</h2>
      <div class="mt-4 space-y-4">
        <label class="block text-sm font-medium text-zinc-200">Nombre
          <input type="text" class="mt-1 w-full rounded-lg border border-zinc-700 px-3 py-2 text-sm focus:border-amber-300 focus:outline-none focus:ring-2 focus:ring-amber-900/40" placeholder="Nombre completo">
        </label>
        <label class="block text-sm font-medium text-zinc-200">Correo
          <input type="email" class="mt-1 w-full rounded-lg border border-zinc-700 px-3 py-2 text-sm focus:border-amber-300 focus:outline-none focus:ring-2 focus:ring-amber-900/40" placeholder="correo@dominio.com">
        </label>
        <label class="block text-sm font-medium text-zinc-200">Asunto
          <input type="text" class="mt-1 w-full rounded-lg border border-zinc-700 px-3 py-2 text-sm focus:border-amber-300 focus:outline-none focus:ring-2 focus:ring-amber-900/40" placeholder="Motivo del mensaje">
        </label>
        <label class="block text-sm font-medium text-zinc-200">Mensaje
          <textarea rows="4" class="mt-1 w-full rounded-lg border border-zinc-700 px-3 py-2 text-sm focus:border-amber-300 focus:outline-none focus:ring-2 focus:ring-amber-900/40" placeholder="Escriba su mensaje"></textarea>
        </label>
        <button type="button" class="w-full rounded-lg bg-black px-4 py-2.5 text-sm font-semibold text-white hover:bg-zinc-700">
          Enviar mensaje
        </button>
      </div>
    </form>
  </div>
</section>
