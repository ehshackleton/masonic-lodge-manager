<% content_for :title, "Inicio | Sistema de Gestion Logial" %>

<section class="mx-auto max-w-7xl px-6 pb-10 pt-14">
  <div class="relative overflow-hidden rounded-3xl border border-zinc-800 bg-gradient-to-br from-zinc-900 via-zinc-950 to-zinc-900 p-8 shadow-2xl">
    <div class="absolute right-0 top-0 h-56 w-56 rounded-full bg-amber-500/10 blur-3xl"></div>
    <div class="absolute bottom-0 left-1/3 h-48 w-48 rounded-full bg-blue-500/10 blur-3xl"></div>
    <div class="relative grid gap-8 lg:grid-cols-2 lg:items-center">
      <div>
        <span class="inline-flex rounded-full border border-amber-800 bg-amber-950/40 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-amber-300">
          Banner institucional
        </span>
        <h1 class="mt-4 text-4xl font-bold tracking-tight text-zinc-100 sm:text-5xl">
          Gestion logial
          <span class="text-amber-300">innovadora</span>,
          moderna y trazable
        </h1>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-zinc-300">
          Una experiencia visual renovada para administrar informacion de la logia con claridad,
          elegancia y control operativo en cada modulo.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/iniciar-sesion" class="rounded-xl bg-black px-5 py-3 text-sm font-semibold text-white hover:bg-zinc-700">Acceso privado</a>
          <a href="/sobre-el-sistema" class="rounded-xl border border-zinc-700 px-5 py-3 text-sm font-semibold text-zinc-200 hover:border-amber-300 hover:text-amber-300">Conocer el sistema</a>
        </div>
      </div>
      <div class="grid gap-3 sm:grid-cols-2">
        <article class="rounded-2xl border border-zinc-800 bg-zinc-950/70 p-4">
          <p class="text-xs uppercase tracking-wide text-zinc-500">Modulos</p>
          <p class="mt-2 text-2xl font-bold text-zinc-100">6+</p>
          <p class="mt-1 text-xs text-zinc-400">Operacion centralizada</p>
        </article>
        <article class="rounded-2xl border border-zinc-800 bg-zinc-950/70 p-4">
          <p class="text-xs uppercase tracking-wide text-zinc-500">Trazabilidad</p>
          <p class="mt-2 text-2xl font-bold text-zinc-100">100%</p>
          <p class="mt-1 text-xs text-zinc-400">Registros auditables</p>
        </article>
        <article class="rounded-2xl border border-zinc-800 bg-zinc-950/70 p-4">
          <p class="text-xs uppercase tracking-wide text-zinc-500">Acceso</p>
          <p class="mt-2 text-2xl font-bold text-zinc-100">RBAC</p>
          <p class="mt-1 text-xs text-zinc-400">Permisos granulares</p>
        </article>
        <article class="rounded-2xl border border-zinc-800 bg-zinc-950/70 p-4">
          <p class="text-xs uppercase tracking-wide text-zinc-500">Interfaz</p>
          <p class="mt-2 text-2xl font-bold text-zinc-100">UX+UI</p>
          <p class="mt-1 text-xs text-zinc-400">Diseno contemporaneo</p>
        </article>
      </div>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 pb-10">
  <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
    <article class="rounded-2xl border border-zinc-800 bg-zinc-900/80 p-5 backdrop-blur">
      <h3 class="text-sm font-semibold text-zinc-100">Cuadro logial</h3>
      <p class="mt-2 text-sm text-zinc-400">Ficha integral de hermanos, grados, cargos e historial.</p>
    </article>
    <article class="rounded-2xl border border-zinc-800 bg-zinc-900/80 p-5 backdrop-blur">
      <h3 class="text-sm font-semibold text-zinc-100">Tesoreria</h3>
      <p class="mt-2 text-sm text-zinc-400">Cuotas, cargos, pagos y reportes financieros.</p>
    </article>
    <article class="rounded-2xl border border-zinc-800 bg-zinc-900/80 p-5 backdrop-blur">
      <h3 class="text-sm font-semibold text-zinc-100">Secretaria</h3>
      <p class="mt-2 text-sm text-zinc-400">Actas y correspondencia con workflow formal.</p>
    </article>
    <article class="rounded-2xl border border-zinc-800 bg-zinc-900/80 p-5 backdrop-blur">
      <h3 class="text-sm font-semibold text-zinc-100">Hospitalario</h3>
      <p class="mt-2 text-sm text-zinc-400">Saco hospitalario y fondo de defuncion.</p>
    </article>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 pb-14">
  <div class="mb-4 flex items-end justify-between">
    <div>
      <h2 class="text-2xl font-bold text-zinc-100">Galeria institucional</h2>
      <p class="mt-1 text-sm text-zinc-400">Espacios visuales para comunicar identidad y actividad.</p>
    </div>
  </div>
  <div class="grid gap-4 md:grid-cols-3">
    <article class="rounded-2xl border border-zinc-800 bg-zinc-900 p-4">
      <div class="group relative h-44 overflow-hidden rounded-xl bg-zinc-950">
        <%= image_tag "/images/galeria_templo.webp",
                      alt: "Templo y ceremonia — marco visual institucional",
                      class: "absolute inset-0 h-full w-full object-cover transition-transform duration-300 ease-out will-change-transform group-hover:scale-105 motion-reduce:transition-none motion-reduce:group-hover:scale-100",
                      loading: "lazy",
                      decoding: "async" %>
      </div>
      <h3 class="mt-3 font-semibold text-zinc-100">Templo y ceremonia</h3>
      <p class="mt-1 text-sm text-zinc-400">Marco visual para actividades rituales.</p>
    </article>
    <article class="rounded-2xl border border-zinc-800 bg-zinc-900 p-4">
      <div class="group relative h-44 overflow-hidden rounded-xl bg-zinc-950">
        <%= image_tag "/images/galeria_biblioteca.webp",
                      alt: "Biblioteca y estudio — formacion y trabajo intelectual",
                      class: "absolute inset-0 h-full w-full object-cover transition-transform duration-300 ease-out will-change-transform group-hover:scale-105 motion-reduce:transition-none motion-reduce:group-hover:scale-100",
                      loading: "lazy",
                      decoding: "async" %>
      </div>
      <h3 class="mt-3 font-semibold text-zinc-100">Biblioteca y estudio</h3>
      <p class="mt-1 text-sm text-zinc-400">Formacion y trabajo intelectual permanente.</p>
    </article>
    <article class="rounded-2xl border border-zinc-800 bg-zinc-900 p-4">
      <div class="group relative h-44 overflow-hidden rounded-xl bg-zinc-950">
        <%= image_tag "/images/galeria_comunidad.webp",
                      alt: "Comunidad fraterna — vinculo social y servicio institucional",
                      class: "absolute inset-0 h-full w-full object-cover transition-transform duration-300 ease-out will-change-transform group-hover:scale-105 motion-reduce:transition-none motion-reduce:group-hover:scale-100",
                      loading: "lazy",
                      decoding: "async" %>
      </div>
      <h3 class="mt-3 font-semibold text-zinc-100">Comunidad fraterna</h3>
      <p class="mt-1 text-sm text-zinc-400">Vinculo social y servicio institucional.</p>
    </article>
  </div>
</section>
