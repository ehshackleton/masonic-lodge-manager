<% content_for :title, "Inicio | Sistema de Gestion Logial" %>

<section class="mx-auto max-w-7xl px-6 pb-10 pt-14">
  <div class="grid gap-8 lg:grid-cols-2 lg:items-center">
    <div>
      <span class="inline-flex rounded-full bg-blue-50 px-3 py-1 text-xs font-semibold uppercase tracking-wide text-brand">
        Portal institucional
      </span>
      <h1 class="mt-4 text-4xl font-bold tracking-tight text-ink sm:text-5xl">
        Administracion logial moderna,
        segura y trazable
      </h1>
      <p class="mt-5 max-w-xl text-lg leading-relaxed text-slate-600">
        Plataforma integral para gestionar cuadro logial, tesoreria, secretaria y trabajos masonicos,
        con control de acceso por roles y separacion estricta entre contenido publico y privado.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/iniciar-sesion" class="rounded-xl bg-ink px-5 py-3 text-sm font-semibold text-white hover:bg-slate-700">Acceso privado</a>
        <a href="/sobre-el-sistema" class="rounded-xl border border-slate-300 px-5 py-3 text-sm font-semibold text-slate-700 hover:border-brand hover:text-brand">Conocer el sistema</a>
      </div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
      <h2 class="text-lg font-semibold text-ink">Destacados V1</h2>
      <ul class="mt-4 space-y-3 text-sm text-slate-600">
        <li class="rounded-lg bg-slate-50 p-3">Portal publico institucional con navegacion clara y responsive.</li>
        <li class="rounded-lg bg-slate-50 p-3">Backoffice privado para gestion administrativa modular.</li>
        <li class="rounded-lg bg-slate-50 p-3">Base preparada para auditoria, permisos por rol y crecimiento multi-logia.</li>
      </ul>
    </div>
  </div>
</section>

<section class="mx-auto max-w-7xl px-6 pb-12">
  <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-4">
    <article class="rounded-xl border border-slate-200 bg-white p-5">
      <h3 class="text-sm font-semibold text-ink">Cuadro logial</h3>
      <p class="mt-2 text-sm text-slate-600">Ficha integral de hermanos, grados, cargos y estado de regularidad.</p>
    </article>
    <article class="rounded-xl border border-slate-200 bg-white p-5">
      <h3 class="text-sm font-semibold text-ink">Tesoreria</h3>
      <p class="mt-2 text-sm text-slate-600">Cuotas, cargos, pagos e historial financiero por periodo.</p>
    </article>
    <article class="rounded-xl border border-slate-200 bg-white p-5">
      <h3 class="text-sm font-semibold text-ink">Secretaria</h3>
      <p class="mt-2 text-sm text-slate-600">Actas, correspondencia y documentos con control de visibilidad.</p>
    </article>
    <article class="rounded-xl border border-slate-200 bg-white p-5">
      <h3 class="text-sm font-semibold text-ink">Trabajos masonicos</h3>
      <p class="mt-2 text-sm text-slate-600">Asignacion, seguimiento, revisiones y presentaciones academicas.</p>
    </article>
  </div>
</section>
