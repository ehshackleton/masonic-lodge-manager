<% content_for :title, "Ficha del hermano | Cuadro logial" %>

<section class="mx-auto max-w-7xl px-6 py-10">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-zinc-100"><%= @brother.full_name.presence || "Hermano sin nombre" %></h1>
      <p class="mt-1 text-sm text-zinc-400">Registro: <%= @brother.registry_number %> - Estado: <%= @brother.membership_status.to_s.humanize %></p>
    </div>
    <div class="flex gap-2">
      <a href="/backoffice/brothers/<%= @brother.id %>/edit" class="rounded-lg border border-zinc-700 px-4 py-2 text-sm font-semibold text-zinc-200">Editar</a>
      <a href="/backoffice/brothers" class="rounded-lg bg-black px-4 py-2 text-sm font-semibold text-white">Volver al listado</a>
    </div>
  </div>

  <div class="mt-6 grid gap-4 lg:grid-cols-2">
    <article class="rounded-xl border border-zinc-800 bg-zinc-900 p-5">
      <h2 class="text-base font-semibold text-zinc-100">Datos logiales</h2>
      <dl class="mt-3 space-y-2 text-sm">
        <div><dt class="font-medium text-zinc-500">Logia</dt><dd><%= @brother.lodge&.name || "-" %></dd></div>
        <div><dt class="font-medium text-zinc-500">Nombre simbolico</dt><dd><%= @brother.symbolic_name.presence || "-" %></dd></div>
        <div><dt class="font-medium text-zinc-500">Grado actual</dt><dd><%= @brother.current_degree&.name || "-" %></dd></div>
        <div><dt class="font-medium text-zinc-500">Estado desde</dt><dd><%= @brother.status_since || "-" %></dd></div>
      </dl>
    </article>

    <article class="rounded-xl border border-zinc-800 bg-zinc-900 p-5">
      <h2 class="text-base font-semibold text-zinc-100">Datos personales</h2>
      <dl class="mt-3 space-y-2 text-sm">
        <div><dt class="font-medium text-zinc-500">Identificador nacional</dt><dd><%= @brother.national_id.presence || "-" %></dd></div>
        <div><dt class="font-medium text-zinc-500">Fecha de nacimiento</dt><dd><%= @brother.birth_date || "-" %></dd></div>
        <div><dt class="font-medium text-zinc-500">Estado civil</dt><dd><%= @brother.marital_status.presence || "-" %></dd></div>
        <div><dt class="font-medium text-zinc-500">Profesion</dt><dd><%= @brother.profession.presence || "-" %></dd></div>
        <div><dt class="font-medium text-zinc-500">Empleador</dt><dd><%= @brother.employer.presence || "-" %></dd></div>
      </dl>
    </article>

    <article class="rounded-xl border border-zinc-800 bg-zinc-900 p-5">
      <h2 class="text-base font-semibold text-zinc-100">Contacto y emergencia</h2>
      <dl class="mt-3 space-y-2 text-sm">
        <div><dt class="font-medium text-zinc-500">Correo</dt><dd><%= @brother.email.presence || "-" %></dd></div>
        <div><dt class="font-medium text-zinc-500">Telefono</dt><dd><%= @brother.phone.presence || "-" %></dd></div>
        <div><dt class="font-medium text-zinc-500">Celular</dt><dd><%= @brother.mobile_phone.presence || "-" %></dd></div>
        <div><dt class="font-medium text-zinc-500">Direccion</dt><dd><%= [@brother.address, @brother.city].compact_blank.join(", ").presence || "-" %></dd></div>
        <div><dt class="font-medium text-zinc-500">Contacto emergencia</dt><dd><%= [@brother.emergency_contact_name, @brother.emergency_contact_phone].compact_blank.join(" - ").presence || "-" %></dd></div>
      </dl>
    </article>

    <article class="rounded-xl border border-zinc-800 bg-zinc-900 p-5">
      <h2 class="text-base font-semibold text-zinc-100">Historial y observaciones</h2>
      <dl class="mt-3 space-y-2 text-sm">
        <div><dt class="font-medium text-zinc-500">Iniciacion</dt><dd><%= @brother.initiation_date || "-" %></dd></div>
        <div><dt class="font-medium text-zinc-500">Exaltacion</dt><dd><%= @brother.exaltation_date || "-" %></dd></div>
        <div><dt class="font-medium text-zinc-500">Elevacion</dt><dd><%= @brother.raising_date || "-" %></dd></div>
        <div><dt class="font-medium text-zinc-500">Fallecimiento</dt><dd><%= @brother.deceased_at || "-" %></dd></div>
        <div><dt class="font-medium text-zinc-500">Observaciones privadas</dt><dd><%= @brother.notes_private.presence || "-" %></dd></div>
      </dl>
    </article>
  </div>

  <div class="mt-6 grid gap-4 lg:grid-cols-2">
    <article class="rounded-xl border border-zinc-800 bg-zinc-900 p-5">
      <h2 class="text-base font-semibold text-zinc-100">Historial de grados</h2>
      <%= form_with model: [:backoffice, @brother, @new_degree_history], class: "mt-4 grid gap-3 md:grid-cols-3" do |f| %>
        <%= f.collection_select :degree_id, @degrees, :id, :name, {}, class: "rounded-lg border border-zinc-700 px-3 py-2 text-sm" %>
        <%= f.date_field :ceremony_date, class: "rounded-lg border border-zinc-700 px-3 py-2 text-sm" %>
        <%= f.submit "Agregar", class: "rounded-lg bg-black px-3 py-2 text-sm font-semibold text-white" %>
        <%= f.text_area :notes, rows: 2, placeholder: "Notas", class: "rounded-lg border border-zinc-700 px-3 py-2 text-sm md:col-span-3" %>
      <% end %>
      <div class="mt-4 space-y-2 text-sm">
        <% @degree_histories.each do |history| %>
          <div class="flex items-start justify-between rounded-lg border border-zinc-800 p-3">
            <div>
              <p class="font-medium text-zinc-100"><%= history.degree.name %> - <%= history.ceremony_date %></p>
              <p class="text-zinc-400"><%= history.notes.presence || "-" %></p>
            </div>
            <%= button_to "Quitar", backoffice_brother_brother_degree_history_path(@brother, history), method: :delete, class: "text-xs font-semibold text-rose-700" %>
          </div>
        <% end %>
        <% if @degree_histories.empty? %>
          <p class="text-zinc-500">Sin registros de grado.</p>
        <% end %>
      </div>
    </article>

    <article class="rounded-xl border border-zinc-800 bg-zinc-900 p-5">
      <h2 class="text-base font-semibold text-zinc-100">Historial de cargos/oficios</h2>
      <%= form_with model: [:backoffice, @brother, @new_office_assignment], class: "mt-4 grid gap-3 md:grid-cols-4" do |f| %>
        <%= f.collection_select :office_id, @offices, :id, :name, {}, class: "rounded-lg border border-zinc-700 px-3 py-2 text-sm md:col-span-2" %>
        <%= f.date_field :start_date, class: "rounded-lg border border-zinc-700 px-3 py-2 text-sm" %>
        <%= f.date_field :end_date, class: "rounded-lg border border-zinc-700 px-3 py-2 text-sm" %>
        <%= f.text_area :notes, rows: 2, placeholder: "Notas", class: "rounded-lg border border-zinc-700 px-3 py-2 text-sm md:col-span-3" %>
        <%= f.submit "Asignar cargo", class: "rounded-lg bg-black px-3 py-2 text-sm font-semibold text-white md:col-span-1" %>
      <% end %>
      <div class="mt-4 space-y-2 text-sm">
        <% @office_assignments.each do |assignment| %>
          <div class="flex items-start justify-between rounded-lg border border-zinc-800 p-3">
            <div>
              <p class="font-medium text-zinc-100"><%= assignment.office.name %></p>
              <p class="text-zinc-400">Desde <%= assignment.start_date %> hasta <%= assignment.end_date || "vigente" %></p>
              <p class="text-zinc-400"><%= assignment.notes.presence || "-" %></p>
            </div>
            <%= button_to "Quitar", backoffice_brother_brother_office_assignment_path(@brother, assignment), method: :delete, class: "text-xs font-semibold text-rose-700" %>
          </div>
        <% end %>
        <% if @office_assignments.empty? %>
          <p class="text-zinc-500">Sin cargos asignados.</p>
        <% end %>
      </div>
    </article>
  </div>

  <article class="mt-6 rounded-xl border border-zinc-800 bg-zinc-900 p-5">
    <h2 class="text-base font-semibold text-zinc-100">Adjuntos y documentos</h2>
    <%= form_with model: [:backoffice, @brother], method: :patch, class: "mt-4 flex flex-wrap items-center gap-3" do |f| %>
      <%= f.file_field :documents, multiple: true, class: "rounded-lg border border-zinc-700 px-3 py-2 text-sm" %>
      <%= f.submit "Subir documentos", class: "rounded-lg bg-black px-4 py-2 text-sm font-semibold text-white" %>
    <% end %>
    <div class="mt-4 space-y-2 text-sm">
      <% @brother.documents.each do |document| %>
        <div class="flex items-center justify-between rounded-lg border border-zinc-800 p-3">
          <div>
            <p class="font-medium text-zinc-100"><%= document.filename.to_s %></p>
            <p class="text-zinc-400"><%= number_to_human_size(document.byte_size) %></p>
          </div>
          <div class="flex items-center gap-3">
            <%= link_to "Ver", rails_blob_path(document, disposition: "attachment"), class: "text-amber-300 hover:underline" %>
            <%= button_to "Eliminar", purge_document_backoffice_brother_path(@brother, attachment_id: document.attachment.id), method: :delete, class: "text-xs font-semibold text-rose-700" %>
          </div>
        </div>
      <% end %>
      <% if @brother.documents.empty? %>
        <p class="text-zinc-500">Sin documentos adjuntos.</p>
      <% end %>
    </div>
  </article>
</section>
