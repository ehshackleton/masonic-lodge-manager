<% content_for :title, "Cuadro logial | Sistema de Gestion Logial" %>

<section class="mx-auto max-w-7xl px-6 py-10">
  <div class="flex flex-wrap items-center justify-between gap-4">
    <div>
      <h1 class="text-3xl font-bold tracking-tight text-zinc-100">Cuadro logial</h1>
      <p class="mt-1 text-sm text-zinc-400">Gestion integral de fichas de hermanos del taller.</p>
    </div>
    <a href="/backoffice/brothers/new" class="rounded-lg bg-black px-4 py-2 text-sm font-semibold text-white hover:bg-zinc-700">
      Agregar hermano
    </a>
  </div>

  <div class="mt-6 rounded-xl border border-zinc-800 bg-zinc-900 p-4">
    <%= form_with url: "/backoffice/brothers", method: :get, class: "grid gap-3 md:grid-cols-4" do %>
      <%= text_field_tag :q, @q, placeholder: "Buscar por nombre, simbolico, registro o ID", class: "rounded-lg border border-zinc-700 px-3 py-2 text-sm md:col-span-2" %>
      <%= select_tag :status, options_for_select([["Todos los estados", ""], ["Activo", "active"], ["Inactivo", "inactive"], ["Suspendido", "suspended"], ["Retirado", "retired"], ["Fallecido", "deceased"]], @status), class: "rounded-lg border border-zinc-700 px-3 py-2 text-sm" %>
      <%= select_tag :degree_id, options_for_select([["Todos los grados", ""]] + @degrees.map { |d| [d.name, d.id] }, @degree_id), class: "rounded-lg border border-zinc-700 px-3 py-2 text-sm" %>
      <button type="submit" class="rounded-lg bg-black px-4 py-2 text-sm font-semibold text-white md:col-span-4 md:w-fit">Filtrar</button>
    <% end %>
  </div>

  <div class="mt-6 overflow-x-auto rounded-xl border border-zinc-800 bg-zinc-900">
    <table class="min-w-full divide-y divide-zinc-800 text-sm">
      <thead class="bg-zinc-950 text-left text-xs uppercase tracking-wide text-zinc-500">
        <tr>
          <th class="px-4 py-3">Registro</th>
          <th class="px-4 py-3">Hermano</th>
          <th class="px-4 py-3">Nombre simbolico</th>
          <th class="px-4 py-3">Grado</th>
          <th class="px-4 py-3">Estado</th>
          <th class="px-4 py-3">Contacto</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-zinc-800">
        <% @brothers.each do |brother| %>
          <tr class="hover:bg-zinc-950">
            <td class="px-4 py-3 font-medium text-zinc-200"><%= brother.registry_number %></td>
            <td class="px-4 py-3"><%= brother.full_name.presence || "-" %></td>
            <td class="px-4 py-3"><%= brother.symbolic_name.presence || "-" %></td>
            <td class="px-4 py-3"><%= brother.current_degree&.name || "-" %></td>
            <td class="px-4 py-3"><%= brother.membership_status.to_s.humanize %></td>
            <td class="px-4 py-3"><%= brother.email.presence || brother.mobile_phone.presence || "-" %></td>
            <td class="px-4 py-3">
              <div class="flex gap-2">
                <a href="/backoffice/brothers/<%= brother.id %>" class="text-amber-300 hover:underline">Ver</a>
                <a href="/backoffice/brothers/<%= brother.id %>/edit" class="text-zinc-200 hover:underline">Editar</a>
              </div>
            </td>
          </tr>
        <% end %>
        <% if @brothers.empty? %>
          <tr>
            <td colspan="7" class="px-4 py-8 text-center text-zinc-500">No se encontraron hermanos con los filtros aplicados.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>
