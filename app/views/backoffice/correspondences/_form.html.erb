<% if @correspondence.errors.any? %><div class="mb-6 rounded-lg border border-amber-800 bg-amber-950/50 p-4 text-sm text-amber-300"><ul class="list-disc pl-5"><% @correspondence.errors.full_messages.each do |m| %><li><%= m %></li><% end %></ul></div><% end %>
<%= form_with model: [:backoffice, @correspondence], class: "space-y-6" do |f| %>
  <div class="rounded-xl border border-zinc-800 bg-zinc-900 p-6 grid gap-4 md:grid-cols-2">
    <label class="text-sm text-zinc-400">Logia<%= f.collection_select :lodge_id, Lodge.order(:name), :id, :name, {}, class: "mt-1 w-full rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %></label>
    <label class="text-sm text-zinc-400">Direccion<%= f.select :direction, Correspondence.directions.keys.map{|k| [k.humanize,k]}, {}, class: "mt-1 w-full rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %></label>
    <label class="text-sm text-zinc-400">Tipo documento<%= f.text_field :document_type, class: "mt-1 w-full rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %></label>
    <label class="text-sm text-zinc-400">Folio<%= f.text_field :folio, class: "mt-1 w-full rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %></label>
    <label class="text-sm text-zinc-400 md:col-span-2">Asunto<%= f.text_field :subject, class: "mt-1 w-full rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %></label>
    <label class="text-sm text-zinc-400">Remitente<%= f.text_field :sender_name, class: "mt-1 w-full rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %></label>
    <label class="text-sm text-zinc-400">Destinatario<%= f.text_field :recipient_name, class: "mt-1 w-full rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %></label>
    <label class="text-sm text-zinc-400">Fecha envio<%= f.date_field :sent_on, class: "mt-1 w-full rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %></label>
    <label class="text-sm text-zinc-400">Fecha recepcion<%= f.date_field :received_on, class: "mt-1 w-full rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %></label>
    <div class="text-sm text-zinc-400">
      Estado actual
      <div class="mt-1 rounded-lg border border-zinc-800 bg-zinc-950 px-3 py-2 text-zinc-200"><%= @correspondence.status.humanize %></div>
    </div>
    <label class="text-sm text-zinc-400">Confidencialidad<%= f.select :confidentiality_level, Correspondence.confidentiality_levels.keys.map{|k| [k.humanize,k]}, {}, class: "mt-1 w-full rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %></label>
    <label class="text-sm text-zinc-400 md:col-span-2">Resumen<%= f.text_area :summary, rows: 3, class: "mt-1 w-full rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %></label>
    <label class="text-sm text-zinc-400 md:col-span-2">Cuerpo<%= f.text_area :body, rows: 7, class: "mt-1 w-full rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %></label>
    <label class="text-sm text-zinc-400 md:col-span-2">Adjuntos<%= f.file_field :documents, multiple: true, class: "mt-1 w-full rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %></label>
  </div>
  <div class="flex gap-2"><%= f.submit(@correspondence.persisted? ? "Actualizar" : "Crear", class: "rounded-lg bg-black px-4 py-2 text-sm font-semibold text-white") %><a href="/backoffice/correspondences" class="rounded-lg border border-zinc-700 px-4 py-2 text-sm text-zinc-200">Cancelar</a></div>
<% end %>
