<% content_for :title, "Correspondencia | Secretaria" %>
<section class="mx-auto max-w-7xl px-6 py-10">
  <div class="flex items-center justify-between">
    <h1 class="text-3xl font-bold text-zinc-100">Correspondencia</h1>
    <div class="flex gap-2">
      <a href="/backoffice/correspondences/export_excel?q=<%= ERB::Util.url_encode(@q.to_s) %>&status=<%= ERB::Util.url_encode(@status.to_s) %>&direction=<%= ERB::Util.url_encode(@direction.to_s) %>" class="rounded-lg border border-zinc-700 px-3 py-2 text-xs font-semibold text-zinc-200 hover:border-amber-300 hover:text-amber-300">Exportar Excel</a>
      <a href="/backoffice/correspondences/export_pdf?q=<%= ERB::Util.url_encode(@q.to_s) %>&status=<%= ERB::Util.url_encode(@status.to_s) %>&direction=<%= ERB::Util.url_encode(@direction.to_s) %>" class="rounded-lg border border-zinc-700 px-3 py-2 text-xs font-semibold text-zinc-200 hover:border-amber-300 hover:text-amber-300">Exportar PDF</a>
      <a href="/backoffice/correspondences/new" class="rounded-lg bg-black px-4 py-2 text-sm text-white">Nueva</a>
    </div>
  </div>
  <%= form_with url: "/backoffice/correspondences", method: :get, class: "mt-4 grid gap-3 md:grid-cols-4" do %>
    <%= text_field_tag :q, @q, placeholder: "Buscar asunto, folio, remitente...", class: "rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100 md:col-span-2" %>
    <%= select_tag :status, options_for_select([["Todos",""]] + Correspondence.statuses.keys.map{|k| [k.humanize,k]}, @status), class: "rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %>
    <%= select_tag :direction, options_for_select([["Todas",""]] + Correspondence.directions.keys.map{|k| [k.humanize,k]}, @direction), class: "rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %>
  <% end %>
  <div class="mt-4 overflow-x-auto rounded-xl border border-zinc-800 bg-zinc-900"><table class="min-w-full divide-y divide-zinc-800 text-sm"><thead class="text-left text-xs uppercase tracking-wide text-zinc-500"><tr><th class="px-4 py-3">Fecha</th><th class="px-4 py-3">Folio</th><th class="px-4 py-3">Asunto</th><th class="px-4 py-3">Direccion</th><th class="px-4 py-3">Estado</th><th class="px-4 py-3">Conf.</th><th class="px-4 py-3"></th></tr></thead><tbody class="divide-y divide-zinc-800">
  <% @correspondences.each do |c| %><tr><td class="px-4 py-3 text-zinc-400"><%= c.sent_on || c.received_on || c.created_at.to_date %></td><td class="px-4 py-3 text-zinc-400"><%= c.folio.presence || '-' %></td><td class="px-4 py-3 text-zinc-200"><%= c.subject %></td><td class="px-4 py-3 text-zinc-400"><%= c.direction.humanize %></td><td class="px-4 py-3 text-zinc-300"><%= c.status.humanize %></td><td class="px-4 py-3 text-zinc-400"><%= c.confidentiality_level.humanize %></td><td class="px-4 py-3"><a class="text-amber-300 hover:underline" href="/backoffice/correspondences/<%= c.id %>">Ver</a></td></tr><% end %>
  <% if @correspondences.empty? %><tr><td colspan="7" class="px-4 py-6 text-zinc-500">Sin correspondencia.</td></tr><% end %>
  </tbody></table></div>
</section>
