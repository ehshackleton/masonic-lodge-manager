<% content_for :title, "Trabajos masonicos | Backoffice" %>
<% content_for :head do %>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<% end %>
<section class="mx-auto max-w-7xl px-6 py-10">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <h1 class="text-3xl font-bold text-zinc-100">Trabajos masonicos</h1>
    <div class="flex flex-wrap gap-2">
      <a href="/backoffice/masonic_works/export_excel?q=<%= ERB::Util.url_encode(@q.to_s) %>&status=<%= ERB::Util.url_encode(@status.to_s) %>&brother_id=<%= ERB::Util.url_encode(@brother_id.to_s) %>&period_from=<%= ERB::Util.url_encode(@period_from.to_s) %>&period_to=<%= ERB::Util.url_encode(@period_to.to_s) %>" class="rounded-lg border border-zinc-700 px-3 py-2 text-xs font-semibold text-zinc-200 hover:border-amber-300 hover:text-amber-300">Exportar trabajos Excel</a>
      <a href="/backoffice/masonic_works/export_pdf?q=<%= ERB::Util.url_encode(@q.to_s) %>&status=<%= ERB::Util.url_encode(@status.to_s) %>&brother_id=<%= ERB::Util.url_encode(@brother_id.to_s) %>&period_from=<%= ERB::Util.url_encode(@period_from.to_s) %>&period_to=<%= ERB::Util.url_encode(@period_to.to_s) %>" class="rounded-lg border border-zinc-700 px-3 py-2 text-xs font-semibold text-zinc-200 hover:border-amber-300 hover:text-amber-300">Exportar trabajos PDF</a>
      <a href="/backoffice/masonic_works/export_reviews_excel?status=<%= ERB::Util.url_encode(@status.to_s) %>&period_from=<%= ERB::Util.url_encode(@period_from.to_s) %>&period_to=<%= ERB::Util.url_encode(@period_to.to_s) %>" class="rounded-lg border border-zinc-700 px-3 py-2 text-xs font-semibold text-zinc-200 hover:border-amber-300 hover:text-amber-300">Exportar revisiones Excel</a>
      <a href="/backoffice/masonic_works/export_reviews_pdf?status=<%= ERB::Util.url_encode(@status.to_s) %>&period_from=<%= ERB::Util.url_encode(@period_from.to_s) %>&period_to=<%= ERB::Util.url_encode(@period_to.to_s) %>" class="rounded-lg border border-zinc-700 px-3 py-2 text-xs font-semibold text-zinc-200 hover:border-amber-300 hover:text-amber-300">Exportar revisiones PDF</a>
      <a href="/backoffice/masonic_works/export_dashboard_pdf?q=<%= ERB::Util.url_encode(@q.to_s) %>&status=<%= ERB::Util.url_encode(@status.to_s) %>&brother_id=<%= ERB::Util.url_encode(@brother_id.to_s) %>&period_from=<%= ERB::Util.url_encode(@period_from.to_s) %>&period_to=<%= ERB::Util.url_encode(@period_to.to_s) %>" class="rounded-lg border border-zinc-700 px-3 py-2 text-xs font-semibold text-zinc-200 hover:border-amber-300 hover:text-amber-300">Exportar tablero PDF</a>
      <a href="/backoffice/masonic_works/new" class="rounded-lg bg-black px-4 py-2 text-sm font-semibold text-white">Nuevo trabajo</a>
    </div>
  </div>

  <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <article class="rounded-xl border border-zinc-800 bg-zinc-900 p-5">
      <p class="text-xs uppercase tracking-wide text-zinc-500">Pendientes</p>
      <p class="mt-2 text-3xl font-semibold text-zinc-100"><%= @productivity_pending %></p>
    </article>
    <article class="rounded-xl border border-zinc-800 bg-zinc-900 p-5">
      <p class="text-xs uppercase tracking-wide text-zinc-500">Aprobados</p>
      <p class="mt-2 text-3xl font-semibold text-zinc-100"><%= @productivity_approved %></p>
    </article>
    <article class="rounded-xl border border-zinc-800 bg-zinc-900 p-5">
      <p class="text-xs uppercase tracking-wide text-zinc-500">Presentados</p>
      <p class="mt-2 text-3xl font-semibold text-zinc-100"><%= @productivity_presented %></p>
    </article>
    <article class="rounded-xl border border-zinc-800 bg-zinc-900 p-5">
      <p class="text-xs uppercase tracking-wide text-zinc-500">Vencidos</p>
      <p class="mt-2 text-3xl font-semibold text-zinc-100"><%= @productivity_overdue %></p>
    </article>
  </div>

  <%= form_with url: "/backoffice/masonic_works", method: :get, class: "mt-4 grid gap-3 md:grid-cols-6" do %>
    <%= text_field_tag :q, @q, placeholder: "Buscar por titulo o tema", class: "rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100 md:col-span-2" %>
    <%= select_tag :status, options_for_select([["Todos",""]] + MasonicWork.statuses.keys.map { |k| [k.humanize, k] }, @status), class: "rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %>
    <%= select_tag :brother_id, options_for_select([["Todos los hermanos",""]] + Brother.order(:last_name, :first_name).map { |b| [b.full_name, b.id] }, @brother_id), class: "rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %>
    <%= date_field_tag :period_from, @period_from, class: "rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %>
    <%= date_field_tag :period_to, @period_to, class: "rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %>
  <% end %>

  <section class="mt-6 rounded-xl border border-zinc-800 bg-zinc-900 p-5">
    <h2 class="text-lg font-semibold text-zinc-100">Productividad mensual (12 meses)</h2>
    <p class="mt-1 text-xs text-zinc-500">Barras para creados/aprobados y linea para presentados.</p>
    <div class="mt-4">
      <canvas id="monthly-productivity-chart" height="120"></canvas>
    </div>
  </section>

  <div class="mt-4 overflow-x-auto rounded-xl border border-zinc-800 bg-zinc-900">
    <table class="min-w-full divide-y divide-zinc-800 text-sm">
      <thead class="text-left text-xs uppercase tracking-wide text-zinc-500">
        <tr>
          <th class="px-4 py-3">Trabajo</th>
          <th class="px-4 py-3">Hermano</th>
          <th class="px-4 py-3">Estado</th>
          <th class="px-4 py-3">Asignacion</th>
          <th class="px-4 py-3">Compromiso</th>
          <th class="px-4 py-3">Revisor</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-zinc-800">
        <% @masonic_works.each do |work| %>
          <tr>
            <td class="px-4 py-3">
              <p class="font-medium text-zinc-100"><%= work.title %></p>
              <p class="text-xs text-zinc-500"><%= work.topic.presence || "Sin tema" %></p>
            </td>
            <td class="px-4 py-3 text-zinc-300"><%= work.brother&.full_name.presence || "-" %></td>
            <td class="px-4 py-3 text-zinc-300"><%= work.status.humanize %></td>
            <td class="px-4 py-3 text-zinc-400"><%= work.assigned_on || "-" %></td>
            <td class="px-4 py-3 text-zinc-400"><%= work.due_on || "-" %></td>
            <td class="px-4 py-3 text-zinc-400"><%= work.reviewer_user&.email.presence || "-" %></td>
            <td class="px-4 py-3"><a class="text-amber-300 hover:underline" href="/backoffice/masonic_works/<%= work.id %>">Ver</a></td>
          </tr>
        <% end %>
        <% if @masonic_works.empty? %>
          <tr><td colspan="7" class="px-4 py-6 text-zinc-500">Sin trabajos registrados.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</section>

<script>
  (function() {
    var canvas = document.getElementById("monthly-productivity-chart");
    if (!canvas || typeof Chart === "undefined") return;
    var series = JSON.parse('<%= raw json_escape(@monthly_productivity_series.to_json) %>');
    var labels = series.map(function(r) { return r.label; });
    var created = series.map(function(r) { return r.created; });
    var approved = series.map(function(r) { return r.approved; });
    var presented = series.map(function(r) { return r.presented; });

    new Chart(canvas.getContext("2d"), {
      data: {
        labels: labels,
        datasets: [
          { type: "bar", label: "Creados", data: created, backgroundColor: "rgba(59, 130, 246, 0.6)", borderColor: "rgba(59, 130, 246, 1)", borderWidth: 1 },
          { type: "bar", label: "Aprobados", data: approved, backgroundColor: "rgba(245, 158, 11, 0.6)", borderColor: "rgba(245, 158, 11, 1)", borderWidth: 1 },
          { type: "line", label: "Presentados", data: presented, borderColor: "rgba(16, 185, 129, 1)", backgroundColor: "rgba(16, 185, 129, 0.2)", tension: 0.3, fill: false, yAxisID: "y" }
        ]
      },
      options: {
        responsive: true,
        interaction: { mode: "index", intersect: false },
        plugins: { legend: { labels: { color: "#d4d4d8" } } },
        scales: {
          x: { ticks: { color: "#a1a1aa" }, grid: { color: "rgba(63,63,70,0.5)" } },
          y: { beginAtZero: true, ticks: { color: "#a1a1aa", precision: 0 }, grid: { color: "rgba(63,63,70,0.5)" } }
        }
      }
    });
  })();
</script>
