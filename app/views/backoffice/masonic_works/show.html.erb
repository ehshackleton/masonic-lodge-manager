<% content_for :title, "Detalle trabajo masonico | Backoffice" %>
<section class="mx-auto max-w-6xl px-6 py-10">
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-3xl font-bold text-zinc-100"><%= @masonic_work.title %></h1>
      <p class="mt-1 text-sm text-zinc-400">Estado actual: <%= @masonic_work.status.humanize %></p>
    </div>
    <div class="flex flex-wrap gap-2">
      <% if @masonic_work.can_submit_review? && current_user&.can_manage_masonic_work_action?(:submit_review) %>
        <%= button_to "Enviar a revision", submit_review_backoffice_masonic_work_path(@masonic_work), method: :patch, class: "rounded-lg border border-zinc-700 px-3 py-2 text-xs font-semibold text-zinc-200 hover:border-amber-300 hover:text-amber-300" %>
      <% end %>
      <% if @masonic_work.can_approve? && current_user&.can_manage_masonic_work_action?(:approve) %>
        <%= button_to "Aprobar", approve_backoffice_masonic_work_path(@masonic_work), method: :patch, class: "rounded-lg border border-zinc-700 px-3 py-2 text-xs font-semibold text-zinc-200 hover:border-amber-300 hover:text-amber-300" %>
      <% end %>
      <% if @masonic_work.can_mark_presented? && current_user&.can_manage_masonic_work_action?(:mark_presented) %>
        <%= button_to "Marcar presentado", mark_presented_backoffice_masonic_work_path(@masonic_work), method: :patch, class: "rounded-lg border border-zinc-700 px-3 py-2 text-xs font-semibold text-zinc-200 hover:border-amber-300 hover:text-amber-300" %>
      <% end %>
      <% if @masonic_work.can_archive? && current_user&.can_manage_masonic_work_action?(:archive) %>
        <%= button_to "Archivar", archive_backoffice_masonic_work_path(@masonic_work), method: :patch, class: "rounded-lg border border-zinc-700 px-3 py-2 text-xs font-semibold text-zinc-200 hover:border-amber-300 hover:text-amber-300" %>
      <% end %>
      <a href="/backoffice/masonic_works/<%= @masonic_work.id %>/edit" class="rounded-lg border border-zinc-700 px-3 py-2 text-sm text-zinc-200">Editar</a>
      <%= button_to "Eliminar", backoffice_masonic_work_path(@masonic_work), method: :delete, class: "rounded-lg border border-amber-800 px-3 py-2 text-sm text-amber-300", form: { data: { turbo_confirm: "Esta accion eliminara el trabajo. Continuar?" } } %>
      <a href="/backoffice/masonic_works" class="rounded-lg bg-black px-3 py-2 text-sm text-white">Volver</a>
    </div>
  </div>

  <div class="mt-6 grid gap-6 lg:grid-cols-3">
    <article class="rounded-xl border border-zinc-800 bg-zinc-900 p-6 text-sm text-zinc-300 lg:col-span-2">
      <p><strong class="text-zinc-100">Hermano:</strong> <%= @masonic_work.brother&.full_name.presence || "-" %></p>
      <p class="mt-2"><strong class="text-zinc-100">Grado:</strong> <%= @masonic_work.degree&.name.presence || "-" %></p>
      <p class="mt-2"><strong class="text-zinc-100">Tema:</strong> <%= @masonic_work.topic.presence || "-" %></p>
      <p class="mt-2"><strong class="text-zinc-100">Revisor:</strong> <%= @masonic_work.reviewer_user&.email.presence || "-" %></p>
      <p class="mt-2"><strong class="text-zinc-100">Asignado:</strong> <%= @masonic_work.assigned_on || "-" %> | <strong class="text-zinc-100">Compromiso:</strong> <%= @masonic_work.due_on || "-" %> | <strong class="text-zinc-100">Presentado:</strong> <%= @masonic_work.presented_on || "-" %></p>
      <div class="mt-4">
        <strong class="text-zinc-100">Resumen:</strong>
        <p class="mt-2 whitespace-pre-wrap"><%= @masonic_work.abstract.presence || "-" %></p>
      </div>
      <div class="mt-4">
        <strong class="text-zinc-100">Cuerpo:</strong>
        <p class="mt-2 whitespace-pre-wrap"><%= @masonic_work.body.presence || "-" %></p>
      </div>
      <div class="mt-4">
        <strong class="text-zinc-100">Notas privadas:</strong>
        <p class="mt-2 whitespace-pre-wrap"><%= @masonic_work.private_notes.presence || "-" %></p>
      </div>
      <div class="mt-4">
        <strong class="text-zinc-100">Adjuntos:</strong>
        <ul class="mt-2 space-y-1">
          <% @masonic_work.documents.each do |doc| %>
            <li><a class="text-amber-300 hover:underline" href="<%= rails_blob_path(doc, disposition: "attachment") %>"><%= doc.filename.to_s %></a></li>
          <% end %>
          <% if @masonic_work.documents.empty? %>
            <li class="text-zinc-500">Sin adjuntos.</li>
          <% end %>
        </ul>
      </div>
    </article>

    <aside class="space-y-6">
      <section class="rounded-xl border border-zinc-800 bg-zinc-900 p-5">
        <h2 class="text-lg font-semibold text-zinc-100">Registrar revision</h2>
        <% if current_user&.can_manage_masonic_work_action?(:create_review) %>
        <%= form_with model: [:backoffice, @masonic_work, @work_review], class: "mt-4 space-y-3" do |f| %>
          <div>
            <%= f.label :reviewer_user_id, "Revisor", class: "mb-1 block text-xs uppercase tracking-wide text-zinc-500" %>
            <%= f.collection_select :reviewer_user_id, User.order(:email), :id, :email, {}, class: "w-full rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %>
          </div>
          <div>
            <%= f.label :reviewed_on, "Fecha", class: "mb-1 block text-xs uppercase tracking-wide text-zinc-500" %>
            <%= f.date_field :reviewed_on, class: "w-full rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %>
          </div>
          <div>
            <%= f.label :status, "Resultado", class: "mb-1 block text-xs uppercase tracking-wide text-zinc-500" %>
            <%= f.select :status, options_for_select(WorkReview.statuses.keys.map { |k| [k.humanize, k] }, @work_review.status), {}, class: "w-full rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %>
          </div>
          <div>
            <%= f.label :comments, "Comentarios", class: "mb-1 block text-xs uppercase tracking-wide text-zinc-500" %>
            <%= f.text_area :comments, rows: 4, class: "w-full rounded-lg border border-zinc-700 bg-zinc-900 px-3 py-2 text-zinc-100" %>
          </div>
          <%= f.submit "Guardar revision", class: "rounded-lg bg-black px-4 py-2 text-sm font-semibold text-white" %>
        <% end %>
        <% else %>
          <p class="mt-3 text-sm text-zinc-500">No tienes permisos para registrar revisiones.</p>
        <% end %>
      </section>

      <section class="rounded-xl border border-zinc-800 bg-zinc-900 p-5">
        <h2 class="text-lg font-semibold text-zinc-100">Bitacora de revisiones</h2>
        <ul class="mt-4 space-y-3">
          <% @work_reviews.each do |review| %>
            <li class="rounded-lg border border-zinc-800 p-3 text-sm text-zinc-300">
              <p><strong class="text-zinc-100"><%= review.reviewed_on %></strong> - <%= review.status.humanize %></p>
              <p class="text-zinc-400">Revisor: <%= review.reviewer_user&.email.presence || "-" %></p>
              <p class="mt-2 whitespace-pre-wrap text-zinc-300"><%= review.comments.presence || "Sin comentarios." %></p>
              <% if current_user&.can_manage_masonic_work_action?(:destroy_review) %>
                <%= button_to "Eliminar", backoffice_masonic_work_work_review_path(@masonic_work, review), method: :delete, class: "mt-2 text-xs text-amber-300 hover:underline", form: { data: { turbo_confirm: "Eliminar revision?" } } %>
              <% end %>
            </li>
          <% end %>
          <% if @work_reviews.empty? %>
            <li class="text-sm text-zinc-500">Sin revisiones registradas.</li>
          <% end %>
        </ul>
      </section>
    </aside>
  </div>

  <section class="mt-6 rounded-xl border border-zinc-800 bg-zinc-900 p-5">
    <h2 class="text-lg font-semibold text-zinc-100">Auditoria reciente</h2>
    <ul class="mt-4 space-y-2 text-sm">
      <% @audit_logs.each do |log| %>
        <li class="rounded-lg border border-zinc-800 px-3 py-2 text-zinc-300">
          <span class="font-medium text-zinc-100"><%= log.created_at.strftime("%d/%m/%Y %H:%M") %></span>
          - <%= log.action %>
          - Usuario: <%= log.user&.email.presence || "sistema" %>
        </li>
      <% end %>
      <% if @audit_logs.empty? %>
        <li class="text-zinc-500">Sin eventos de auditoria.</li>
      <% end %>
    </ul>
  </section>
</section>
